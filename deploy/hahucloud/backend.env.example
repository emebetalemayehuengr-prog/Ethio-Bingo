APP_ENV=production
APP_PORT=8012
APP_NAME=40bingo API

# Preferred DB keys
FORTY_BINGO_DB_PATH=/home/<cpanel-user>/apps/40bingo-backend/data/40bingo.db
FORTY_BINGO_FALLBACK_DB_PATH=
PERSISTENT_SQLITE_ROOTS=/var/data,/home

# Optional Postgres
DATABASE_URL=

# Auth / app behavior
SESSION_TTL_SECONDS=86400
ENABLE_DEMO_SEED=false
ENABLE_SIMULATED_ACTIVITY=true
ENABLE_INTERNAL_TRANSFER=false
SIGNUP_INITIAL_MAIN_BALANCE=0
SIGNUP_INITIAL_BONUS_BALANCE=0

# CORS
CORS_ALLOWED_ORIGINS=https://40bingo.com
CORS_ALLOWED_ORIGIN_REGEX=

# Admin alerts
ADMIN_BOOTSTRAP_PHONES=
ADMIN_ALERT_EMAILS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Optional integrations
TELEGRAM_BOT_TOKEN=
TRANSFER_OTP_VERIFY_URL=
TRANSFER_OTP_VERIFY_TIMEOUT_SECONDS=6
